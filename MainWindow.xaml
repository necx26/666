<Window x:Class="necx炒股分析大师.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:local="clr-namespace:necx炒股分析大师"
        Title="股票一键查" Height="850" Width="1300"
        Background="#0A0E14" WindowStyle="None" AllowsTransparency="True" WindowStartupLocation="CenterScreen" Cursor="">

    <Window.Resources>
        <local:StockColorConverter x:Key="StockColorConverter"/>

        <Style x:Key="AnimatedBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtnStyle" TargetType="Button" BasedOn="{StaticResource AnimatedBtnStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="Transparent" CornerRadius="0,10,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PeriodBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1F2B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border" 
                                                       Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                       To="#3A445C" Duration="0:0:0.2"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="border" 
                                                       Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                       To="#1A1F2B" Duration="0:0:0.3"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="SnapsToDevicePixels" Value="true"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border x:Name="DGR_Border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="True">
                            <SelectiveScrollingGrid>
                                <SelectiveScrollingGrid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </SelectiveScrollingGrid.ColumnDefinitions>
                                <SelectiveScrollingGrid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </SelectiveScrollingGrid.RowDefinitions>
                                <DataGridCellsPresenter Grid.Column="1" ItemsPanel="{TemplateBinding ItemsPanel}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                                <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1" Visibility="{TemplateBinding DetailsVisibility}" />
                            </SelectiveScrollingGrid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="DGR_Border" 
                                                           Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                           To="#2A3042" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="DGR_Border" 
                                                           Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)" 
                                                           To="Transparent" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#1A1F2B" BorderThickness="1" Background="#0A0E14" CornerRadius="10">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#151921" MouseLeftButtonDown="Header_MouseLeftButtonDown" CornerRadius="10,10,0,0">
                <Grid>
                    <TextBlock Foreground="#5865F2" FontWeight="Bold" VerticalAlignment="Center" Margin="15,0"><Run Language="zh-cn" Text="股票一键查"/></TextBlock>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="—" Foreground="#A0AEC0" Width="40" Click="MinBtn_Click" Style="{StaticResource AnimatedBtnStyle}"/>
                        <Button Content="✕" Foreground="#A0AEC0" Width="40" Click="CloseBtn_Click" Style="{StaticResource CloseBtnStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" x:Name="SidePanel" Width="380" Opacity="1">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="SideTransform" X="0"/>
                    </Grid.RenderTransform>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#151921" CornerRadius="5" Margin="0,0,10,10" Padding="5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchBox" Background="#1A1F2B" BorderThickness="0" Foreground="White" VerticalContentAlignment="Center" FontSize="14" Padding="10,5" KeyDown="SearchBox_KeyDown"/>
                            <Button Grid.Column="1" Content="搜索" Click="SearchBtn_Click" Style="{StaticResource PeriodBtnStyle}" Foreground="#FFF1A3FF"/>
                        </Grid>
                    </Border>

                    <DataGrid x:Name="StockDataGrid" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True" RowBackground="#151921" BorderThickness="0" 
                              SelectionChanged="StockDataGrid_SelectionChanged" Foreground="Red" Margin="0,0,10,0">
                        <DataGrid.Background>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FF0D0A0D"/>
                                <GradientStop Color="#FF1D1F2D" Offset="1"/>
                                <GradientStop Color="#FF171F15" Offset="0.53"/>
                            </LinearGradientBrush>
                        </DataGrid.Background>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="代码" Binding="{Binding Code}" Width="80"/>
                            <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="现价" Binding="{Binding Price}" Width="70"/>
                            <DataGridTemplateColumn Header="涨跌" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Change}" FontWeight="Bold" Foreground="{Binding Change, Converter={StaticResource StockColorConverter}}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <ToggleButton Grid.Column="1" x:Name="ToggleSideBtn" Width="30" VerticalAlignment="Stretch" Background="Transparent" BorderThickness="0">
                    <ToggleButton.Template>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="btnBorder" Background="Transparent" CornerRadius="4" Cursor="Hand">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Rectangle Width="18" Height="2" Fill="#5865F2" Margin="0,3"/>
                                    <Rectangle Width="18" Height="2" Fill="#5865F2" Margin="0,3"/>
                                    <Rectangle Width="18" Height="2" Fill="#5865F2" Margin="0,3"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="#1A1F2B"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </ToggleButton.Template>

                    <ToggleButton.Triggers>
                        <EventTrigger RoutedEvent="ToggleButton.Checked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SideTransform" Storyboard.TargetProperty="X" To="-380" Duration="0:0:0.4">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <ThicknessAnimation Storyboard.TargetName="SidePanel" Storyboard.TargetProperty="Margin" To="0,0,-380,0" Duration="0:0:0.4">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                    <DoubleAnimation Storyboard.TargetName="SidePanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="ToggleButton.Unchecked">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="SideTransform" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.4">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <ThicknessAnimation Storyboard.TargetName="SidePanel" Storyboard.TargetProperty="Margin" To="0,0,0,0" Duration="0:0:0.4">
                                        <ThicknessAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseInOut"/>
                                        </ThicknessAnimation.EasingFunction>
                                    </ThicknessAnimation>
                                    <DoubleAnimation Storyboard.TargetName="SidePanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.4"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ToggleButton.Triggers>
                </ToggleButton>

                <Grid Grid.Column="2" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="250"/>
                    </Grid.RowDefinitions>

                    <Border Background="#1C222D" CornerRadius="8" Padding="15">
                        <Grid>
                            <DockPanel VerticalAlignment="Top" Height="35">
                                <TextBlock x:Name="TargetStockName" Text=">>> 请选择股票" FontWeight="Bold" VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <LinearGradientBrush EndPoint="1,1" StartPoint="0,0">
                                            <GradientStop Color="#FF9DAA56"/>
                                            <GradientStop Color="#FF00C7FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </TextBlock.Foreground>
                                </TextBlock>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="分时" Tag="min" Click="PeriodBtn_Click" Style="{StaticResource PeriodBtnStyle}" Foreground="#FFDDFFC6"/>
                                    <Button Content="日K" Tag="day" Click="PeriodBtn_Click" Style="{StaticResource PeriodBtnStyle}" Foreground="#FFDFFFC9"/>
                                    <Button Content="周K" Tag="week" Click="PeriodBtn_Click" Style="{StaticResource PeriodBtnStyle}" Foreground="#FFD7FFB4"/>
                                </StackPanel>
                            </DockPanel>

                            <lvc:CartesianChart x:Name="MainChart" Margin="0,45,0,10" Hoverable="False" DataTooltip="{x:Null}">
                                <lvc:CartesianChart.Series>
                                    <lvc:CandleSeries x:Name="OhlcSeries" StrokeThickness="1" IncreaseBrush="#FF3366" DecreaseBrush="#00F5D4"/>
                                    <lvc:LineSeries x:Name="TimeLineSeries" Stroke="#5865F2" Fill="Transparent" PointGeometry="{x:Null}" StrokeThickness="2"/>
                                </lvc:CartesianChart.Series>
                                <lvc:CartesianChart.AxisX>
                                    <lvc:Axis x:Name="XAxis" Foreground="#4A5568">
                                        <lvc:Axis.Separator>
                                            <lvc:Separator Step="1" IsEnabled="False"/>
                                        </lvc:Axis.Separator>
                                    </lvc:Axis>
                                </lvc:CartesianChart.AxisX>
                            </lvc:CartesianChart>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Background="#13171F" CornerRadius="8" Margin="0,15,0,0" Padding="15">
                        <Grid x:Name="BottomInfoPanel">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border BorderBrush="#1A1F2B" BorderThickness="0,0,1,0">
                                <ItemsControl ItemsSource="{Binding BidAsk}" Foreground="#FF241E25">
                                    <ItemsControl.Background>
                                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="1.2,0">
                                            <GradientStop Color="#FFFBBEFF"/>
                                            <GradientStop Color="#FFB0FFF5" Offset="1"/>
                                        </LinearGradientBrush>
                                    </ItemsControl.Background>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#FF322828" FontSize="12" Margin="0,2" FontFamily="Consolas"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>

                            <Grid Grid.Column="1" Margin="15,0,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <UniformGrid Columns="4" Rows="2">
                                    <StackPanel Margin="5">
                                        <TextBlock Text="现价" Foreground="#FFE3DFA7" FontSize="11"/>
                                        <TextBlock Text="{Binding Price}" Foreground="#FFD700" FontWeight="Bold" FontSize="16"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="今开" Foreground="#FFB3D2FF" FontSize="11"/>
                                        <TextBlock Text="{Binding Open}" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="最高" Foreground="#FFFFA3A3" FontSize="11"/>
                                        <TextBlock Text="{Binding High}" Foreground="#FF3366" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="最低" Foreground="#FF9CFF95" FontSize="11"/>
                                        <TextBlock Text="{Binding Low}" Foreground="#00F5D4" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="总市值" Foreground="#FFC4E7C3" FontSize="11"/>
                                        <TextBlock Text="{Binding MC}" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="流通市值" Foreground="#FFA5C9FF" FontSize="11"/>
                                        <TextBlock Text="{Binding FMC}" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="市盈率" Foreground="#FFA6CAFF" FontSize="11"/>
                                        <TextBlock Text="{Binding PE}" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                    <StackPanel Margin="5">
                                        <TextBlock Text="量比" Foreground="#FF98C2FF" FontSize="11"/>
                                        <TextBlock Text="{Binding Ratio}" Foreground="#5865F2" FontSize="14"/>
                                    </StackPanel>
                                </UniformGrid>

                                <Grid Grid.Row="1" VerticalAlignment="Bottom">
                                    <TextBlock x:Name="AIAnalysisText" Text="[ 系统就绪 ]" Foreground="#4A5568" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>

                                    <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" 
        Width="24" Height="24" CornerRadius="12" 
        Background="#1AFFFFFF" Cursor="Hand"
        MouseUp="Border_MouseUp" ToolTip="关于软件">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#5865F2" Duration="0:0:0.3"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#1AFFFFFF" Duration="0:0:0.3"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="!" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>